/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "lib": ["ES2025", "ESNext.Temporal", "DOM"]
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/proof-01/tsconfig.app.json"
    },
    {
      "path": "./projects/proof-01/tsconfig.spec.json"
    },
    {
      "path": "./projects/demo-01/tsconfig.app.json"
    },
    {
      "path": "./projects/demo-01/tsconfig.spec.json"
    },
    {
      "path": "./projects/demo-02/tsconfig.app.json"
    },
    {
      "path": "./projects/demo-02/tsconfig.spec.json"
    },
    {
      "path": "./projects/demo-03/tsconfig.app.json"
    },
    {
      "path": "./projects/demo-03/tsconfig.spec.json"
    }
  ]
}
