{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false,
    "schematicCollections": ["angular-eslint"]
  },
  "newProjectRoot": "projects",
  "projects": {
    "proof-01": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "inlineTemplate": true,
          "inlineStyle": true
        }
      },
      "root": "projects/proof-01",
      "sourceRoot": "projects/proof-01/src",
      "prefix": "alc",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/proof-01/src/main.ts",
            "tsConfig": "projects/proof-01/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/proof-01/public"
              }
            ],
            "styles": ["projects/proof-01/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "proof-01:build:production"
            },
            "development": {
              "buildTarget": "proof-01:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/proof-01/**/*.ts", "projects/proof-01/**/*.html"],
            "eslintConfig": "projects/proof-01/eslint.config.js"
          }
        },
        "e2e": {
          "builder": "playwright-ng-schematics:playwright"
        }
      }
    },
